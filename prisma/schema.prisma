generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  DISPATCHER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  OUT_OF_SERVICE
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  NEW
  IN_PROGRESS
  COMPLETED
}

enum DriverDutyStatus {
  ON_DUTY
  OFF_DUTY
  SUSPENDED
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  driver    Driver?
}

model Vehicle {
  id                      Int              @id @default(autoincrement())
  name                    String?
  model                   String
  licensePlate            String           @unique
  type                    String
  maxCapacityKg           Float
  currentOdometer         Int
  acquisitionCost         Float?
  requiredLicenseCategory String?
  status                  VehicleStatus    @default(AVAILABLE)
  year                    Int?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  trips                   Trip[]
  maintenanceLogs         MaintenanceLog[]
  fuelLogs                FuelLog[]
  expenses                Expense[]

  @@index([status])
}

model Driver {
  id              Int              @id @default(autoincrement())
  name            String
  licenseNumber   String           @unique
  licenseExpiry   DateTime
  licenseCategory String?
  safetyScore     Float            @default(100)
  completionRate  Float            @default(0)
  complaints      Int              @default(0)
  dutyStatus      DriverDutyStatus @default(ON_DUTY)
  userId          Int?             @unique
  user            User?            @relation(fields: [userId], references: [id])
  trips           Trip[]
  expenses        Expense[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([dutyStatus])
}

model Trip {
  id                Int        @id @default(autoincrement())
  origin            String
  destination       String
  cargoWeightKg     Float
  estimatedFuelCost Float?
  revenue           Float?
  finalOdometer     Int?
  status            TripStatus @default(DRAFT)
  vehicleId         Int
  driverId          Int
  vehicle           Vehicle    @relation(fields: [vehicleId], references: [id])
  driver            Driver     @relation(fields: [driverId], references: [id])
  fuelLogs          FuelLog[]
  expenses          Expense[]
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([vehicleId])
  @@index([driverId])
  @@index([status])
}

model MaintenanceLog {
  id        Int               @id @default(autoincrement())
  vehicleId Int
  issue     String
  cost      Float
  status    MaintenanceStatus @default(NEW)
  date      DateTime          @default(now())
  vehicle   Vehicle           @relation(fields: [vehicleId], references: [id])
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([vehicleId])
}

model FuelLog {
  id        Int      @id @default(autoincrement())
  vehicleId Int
  tripId    Int?
  liters    Float
  cost      Float
  distance  Float
  date      DateTime @default(now())
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
  trip      Trip?    @relation(fields: [tripId], references: [id])

  @@index([vehicleId])
  @@index([tripId])
}

model Expense {
  id        Int      @id @default(autoincrement())
  vehicleId Int
  tripId    Int?
  driverId  Int?
  amount    Float
  category  String
  date      DateTime @default(now())
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
  trip      Trip?    @relation(fields: [tripId], references: [id])
  driver    Driver?  @relation(fields: [driverId], references: [id])

  @@index([vehicleId])
  @@index([tripId])
}
